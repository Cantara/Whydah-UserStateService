        <!--
            Jackson dependency strategy — READ THIS:
            ══════════════════════════════════════════════════════════════════
            logstash-logback-encoder 9.x requires Jackson 3.x (tools.jackson).

            Jackson 3.x changed groupId for jackson-core and jackson-databind:
              com.fasterxml.jackson.core  →  tools.jackson.core

            EXCEPTION: jackson-annotations intentionally stays at the
            com.fasterxml.jackson.core groupId even in Jackson 3.x.
            tools.jackson:jackson-databind 3.x has a compile dependency on
            com.fasterxml.jackson.core:jackson-annotations 2.x BY DESIGN.
            See: https://cowtowncoder.medium.com/jackson-3-0-0-ga-released-1f669cda529a

            Therefore:
              ✅ tools.jackson.core:jackson-core            (must be on classpath)
              ✅ tools.jackson.core:jackson-databind         (must be on classpath)
              ✅ com.fasterxml.jackson.core:jackson-annotations 2.x  (REQUIRED, keep it)
              ❌ com.fasterxml.jackson.core:jackson-core     (must be EXCLUDED)
              ❌ com.fasterxml.jackson.core:jackson-databind (must be EXCLUDED)
            ══════════════════════════════════════════════════════════════════
        -->
        <jackson3.version>3.1.0</jackson3.version>

        <jackson.annotations.version>2.21</jackson.annotations.version>

        <resilience4j-basecommands.version>0.8.57</resilience4j-basecommands.version>
        <resilience4j-circuitbreaker.version>2.3.0</resilience4j-circuitbreaker.version>
        <apache.httpclient.version>4.5.14</apache.httpclient.version>
        <hibernate-hikaricp.version>6.6.42.Final</hibernate-hikaricp.version>
        <flyway.version>11.8.1</flyway.version>
        <h2.version>2.4.240</h2.version>
        <postgresql.version>42.7.10</postgresql.version>
        <unirest-java.version>3.14.5</unirest-java.version>
        <hibernate-core.version>6.6.42.Final</hibernate-core.version>
        <freemarker.version>2.3.34</freemarker.version>
        <maven-enforcer-plugin.version>3.0.0</maven-enforcer-plugin.version>
        <maven-surefire-plugin.version>3.5.5</maven-surefire-plugin.version>
        <lucene.version>8.11.2</lucene.version>
        <lucene.analyzers.common.version>8.11.2</lucene.analyzers.common.version>
    </properties>

